{
  "info": {
    "name": "crAPI Payments Service",
    "description": "Payment simulation microservice for crAPI. All endpoints require the 5 security headers generated by the pre-request scripts. Collection-level scripts generate fresh timestamps, request IDs, and idempotency keys per request.\n\nState machine: auth → reversal | capture → void-capture | refund → void-refund\n\nRun the 'Full Chain' folder in order to exercise the complete auth→capture→refund→void-refund flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": { "major": 1, "minor": 0, "patch": 0 }
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:8001",     "type": "string" },
    { "key": "merchantId",  "value": "merch_7f2a91",              "type": "string" },
    { "key": "terminalId",  "value": "TERM-001",                  "type": "string" },
    { "key": "authTxnId",   "value": "",                          "type": "string", "description": "Set by 'Auth' request" },
    { "key": "authId",      "value": "",                          "type": "string", "description": "Set by 'Auth' request (short code e.g. AUTH-1234)" },
    { "key": "saleTxnId",   "value": "",                          "type": "string", "description": "Set by 'Sale' request" },
    { "key": "captureTxnId","value": "",                          "type": "string", "description": "Set by 'Capture' request" },
    { "key": "refundTxnId", "value": "",                          "type": "string", "description": "Set by 'Refund' request" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate a fresh ISO-8601 timestamp within the 5-min replay window",
          "pm.collectionVariables.set('_ts', new Date().toISOString().replace(/\\.\\d+Z$/, 'Z'));",
          "",
          "// Unique request ID for dedup (UUID v4 without dashes, max 64 chars)",
          "function uuidv4() {",
          "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
          "    var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);",
          "    return v.toString(16);",
          "  });",
          "}",
          "pm.collectionVariables.set('_rid', uuidv4());",
          "",
          "// Idempotency key (new per request — override per-request if you want replay testing)",
          "if (!pm.variables.get('_ikey_override')) {",
          "  pm.collectionVariables.set('_ikey', uuidv4());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/payments/api/payments/health",
          "host": ["{{baseUrl}}"],
          "path": ["payments", "api", "payments", "health"]
        },
        "description": "Liveness/readiness probe. No auth headers required. Returns {status: 'ok'}."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('service ok', () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.status).to.eql('ok');",
              "  pm.expect(b.service).to.eql('crapi-payments');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Full Chain",
      "description": "Run these requests in order to exercise: auth → capture → partial refund → void-refund. Transaction IDs are chained automatically via collection variables.",
      "item": [
        {
          "name": "1. Authorize",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",              "value": "application/json" },
              { "key": "X-RequestID",               "value": "{{_rid}}" },
              { "key": "X-Levo-Merchant-Id",        "value": "{{merchantId}}" },
              { "key": "X-Levo-Terminal-Id",        "value": "{{terminalId}}" },
              { "key": "X-Levo-Request-Timestamp",  "value": "{{_ts}}" },
              { "key": "X-Levo-Idempotency-Key",    "value": "{{_ikey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction\": {\n    \"amount\": { \"value\": 15000, \"currency\": \"USD\" },\n    \"order\": {\n      \"order_id\": \"ORD-DEMO-001\",\n      \"line_items\": [\n        { \"sku\": \"ITEM-A\", \"quantity\": 1, \"unit_price\": 15000, \"merchant_category_code\": \"5999\" }\n      ]\n    }\n  },\n  \"card\": {\n    \"number\": \"4111111111111111\",\n    \"exp_month\": 12,\n    \"exp_year\": 2030,\n    \"cvv\": \"123\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/api/payments/auth",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "api", "payments", "auth"]
            },
            "description": "Authorize a card for $150.00. Saves transaction_id and auth_id to collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('status authorized', () => pm.expect(b.transaction.status).to.eql('authorized'));",
                  "pm.test('has auth_id', () => pm.expect(b.transaction.auth_id).to.match(/^AUTH-/));",
                  "pm.test('has approval_code', () => pm.expect(b.authorization.approval_code).to.match(/^APR-/));",
                  "pm.collectionVariables.set('authTxnId', b.transaction.transaction_id);",
                  "pm.collectionVariables.set('authId', b.transaction.auth_id);",
                  "console.log('authTxnId =', b.transaction.transaction_id);",
                  "console.log('authId =', b.transaction.auth_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Capture",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",              "value": "application/json" },
              { "key": "X-RequestID",               "value": "{{_rid}}" },
              { "key": "X-Levo-Merchant-Id",        "value": "{{merchantId}}" },
              { "key": "X-Levo-Terminal-Id",        "value": "{{terminalId}}" },
              { "key": "X-Levo-Request-Timestamp",  "value": "{{_ts}}" },
              { "key": "X-Levo-Idempotency-Key",    "value": "{{_ikey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_transaction_id\": \"{{authTxnId}}\",\n  \"capture\": {\n    \"amount\": { \"value\": 15000, \"currency\": \"USD\" },\n    \"descriptor\": \"ACME STORE #42\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/api/payments/capture",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "api", "payments", "capture"]
            },
            "description": "Capture the authorized amount. References authTxnId set by step 1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('status captured', () => pm.expect(b.transaction.status).to.eql('captured'));",
                  "pm.test('has batch_id', () => pm.expect(b.settlement_schedule.batch_id).to.match(/^BATCH-/));",
                  "pm.collectionVariables.set('captureTxnId', b.transaction.transaction_id);",
                  "console.log('captureTxnId =', b.transaction.transaction_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Partial Refund",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",              "value": "application/json" },
              { "key": "X-RequestID",               "value": "{{_rid}}" },
              { "key": "X-Levo-Merchant-Id",        "value": "{{merchantId}}" },
              { "key": "X-Levo-Terminal-Id",        "value": "{{terminalId}}" },
              { "key": "X-Levo-Request-Timestamp",  "value": "{{_ts}}" },
              { "key": "X-Levo-Idempotency-Key",    "value": "{{_ikey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_transaction_id\": \"{{captureTxnId}}\",\n  \"refund\": {\n    \"amount\": { \"value\": 5000, \"currency\": \"USD\" },\n    \"reason\": { \"code\": \"CUSTOMER_REQUEST\", \"description\": \"Customer changed mind on item\" }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/api/payments/refund",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "api", "payments", "refund"]
            },
            "description": "Refund $50.00 of the $150.00 capture. remaining_refundable should be $100.00 (10000 cents)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('status refunded', () => pm.expect(b.transaction.status).to.eql('refunded'));",
                  "pm.test('remaining correct', () => pm.expect(b.refund.remaining_refundable.value).to.eql(10000));",
                  "pm.collectionVariables.set('refundTxnId', b.transaction.transaction_id);",
                  "console.log('refundTxnId =', b.transaction.transaction_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Void Refund",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",              "value": "application/json" },
              { "key": "X-RequestID",               "value": "{{_rid}}" },
              { "key": "X-Levo-Merchant-Id",        "value": "{{merchantId}}" },
              { "key": "X-Levo-Terminal-Id",        "value": "{{terminalId}}" },
              { "key": "X-Levo-Request-Timestamp",  "value": "{{_ts}}" },
              { "key": "X-Levo-Idempotency-Key",    "value": "{{_ikey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_transaction_id\": \"{{refundTxnId}}\",\n  \"void\": {\n    \"reason\": { \"code\": \"REFUND_ERROR\" },\n    \"timing\": { \"credit_batch_id\": \"\" }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/api/payments/void-refund",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "api", "payments", "void-refund"]
            },
            "description": "Cancel (void) the refund from step 3. remaining_refundable on the capture is restored to full $150.00 (15000 cents)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('status void_refund_complete', () => pm.expect(b.transaction.status).to.eql('void_refund_complete'));",
                  "pm.test('full amount restored', () => pm.expect(b.capture_status.remaining_refundable.value).to.eql(15000));"
                ]
              }
            }
          ]
        }
      ]
    },
